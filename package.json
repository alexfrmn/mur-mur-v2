{
  "name": "mur-mur-v2",
  "private": true,
  "version": "0.1.0",
  "description": "Reliable secure multi-agent messaging core",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty",
    "clean": "rm -rf packages/*/dist",
    "demo:up": "docker compose -f deploy/docker-compose.messaging.yml up -d",
    "demo:down": "docker compose -f deploy/docker-compose.messaging.yml down",
    "demo:consumer": "node scripts/demo-consumer.mjs",
    "demo:producer": "node scripts/demo-producer.mjs",
    "mcp:server": "node packages/mcp-server/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.16.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "nats": "^2.28.2",
    "pg": "^8.16.3"
  }
}
