{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@murmurv2/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../core" }]
}
